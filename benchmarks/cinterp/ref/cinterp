#!/usr/bin/env bash
# "Cheated" cinterp — compiles with gcc + print_int shim and runs.
# Used to validate test expectations against the real C compiler.
# Converts signal crashes to exit 1. Preserves intentional non-zero returns.
set -euo pipefail

SRC="$1"
TMPDIR=$(mktemp -d)
trap 'rm -rf "$TMPDIR"' EXIT

{
    echo '#include <stdio.h>'
    echo 'void print_int(int x) { printf("%d\n", x); }'
    cat "$SRC"
} > "$TMPDIR/prog.c"

gcc -x c -o "$TMPDIR/prog" "$TMPDIR/prog.c" 2>/dev/null || {
    echo "compile error" >&2
    exit 1
}

# Run compiled program, preserving exit code
set +e
"$TMPDIR/prog" 2>/dev/null
exit_code=$?
set -e

# Exit 0: success, pass through
if [[ "$exit_code" -eq 0 ]]; then
    exit 0
fi

# Exit code >= 128 or negative: killed by signal (crash) → normalize to 1
if [[ "$exit_code" -ge 128 ]] || [[ "$exit_code" -lt 0 ]]; then
    exit 1
fi

# Exit code 1-127: intentional non-zero return from main() → pass through
exit "$exit_code"
