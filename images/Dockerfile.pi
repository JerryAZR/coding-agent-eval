# Layered pi worker extending the locally-built cae-worker-fat.
# Use this when the upstream python image is not available (e.g. no Docker
# Hub access) and cae-worker-fat was built with build-local-image.sh.
#
# Build:
#   podman build -f images/Dockerfile.pi -t cae-worker-pi .

FROM cae-worker-fat

# cae-worker-fat already has Python, Node.js, Go, Rust, and Java.
# Install the pi coding agent on top.
RUN npm install -g @earendil-works/pi-coding-agent

# `pi` is now in PATH
LABEL role=worker
ENTRYPOINT ["python", "-m", "cae.worker"]
